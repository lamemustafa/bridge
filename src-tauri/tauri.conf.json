{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bridge",
  "version": "0.2.0",
  "identifier": "com.complyeaze.bridge",
  "build": {
    "beforeDevCommand": "corepack pnpm run dev",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "corepack pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bridge",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://complyeaze.com; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "Copyright 2026 ComplyEaze contributors",
    "license": "Apache-2.0",
    "licenseFile": "../LICENSE",
    "resources": {
      "../LICENSE": "LICENSE",
      "../NOTICE": "NOTICE",
      "../THIRD_PARTY_LICENSES.txt": "THIRD_PARTY_LICENSES.txt",
      "../THIRD_PARTY_LICENSES_RUST.txt": "THIRD_PARTY_LICENSES_RUST.txt"
    },
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
