{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bridge",
  "version": "0.1.0",
  "identifier": "com.complyeaze.bridge",
  "build": {
    "beforeDevCommand": "corepack pnpm run dev",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "corepack pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bridge",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://complyeaze.com; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
